{
  "name": "main",
  "version": "1.0.0",
  "private": true,
  "description": "Projeto Next.js + TypeScript do Nexus Universe.",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:next",
    "dev:next": "next dev",
    "build": "next build",
    "build:next": "next build",
    "start": "next start",
    "start:next": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:strict": "eslint -c eslint.strict.config.js . --ext .ts,.tsx,.js,.jsx",
    "lint:strict:fix": "eslint -c eslint.strict.config.js . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "images:webp": "node scripts/convert-images-to-webp.mjs",
    "generate:component": "node scripts/generate-component.mjs",
    "generate:page": "node scripts/generate-page.mjs",
    "ci:local": "node scripts/run-local-ci.mjs",
    "ci:act": "act",
    "test:a11y": "node scripts/test-a11y.mjs",
    "test:accessibility": "node scripts/test-a11y.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rimraf .next dist node_modules/.cache",
    "analyze": "cross-env ANALYZE=true next build",
    "dev:turbo": "next dev --turbo",
    "quality": "npm run type-check && npm run lint && npm run format:check",
    "quality:fix": "npm run lint:fix && npm run format",
    "dev:debug": "cross-env NODE_OPTIONS='--inspect' next dev",
    "deps:check": "npm outdated",
    "deps:update": "npm update",
    "setup:ci": "node scripts/setup-ci.mjs",
    "bundle:analyze": "cross-env ANALYZE=true next build",
    "prepare": "husky install",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@google/model-viewer": "^4.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-virtual": "^3.13.23",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/three": "^0.183.1",
    "axios": "^1.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.23.12",
    "fuse.js": "^7.1.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.511.0",
    "next": "^16.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.72.0",
    "react-intersection-observer": "^10.0.3",
    "tailwind-merge": "^3.3.0",
    "three": "^0.183.2",
    "vitest": "^4.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/addon-links": "^8.0.0",
    "@storybook/blocks": "^8.0.0",
    "@storybook/nextjs": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/test": "^8.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.0.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.8.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "husky": "^8.0.3",
    "jest-axe": "^8.0.0",
    "lint-staged": "^15.2.0",
    "msw": "^2.12.13",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5",
    "sharp": "^0.34.4",
    "storybook": "^8.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^7.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
